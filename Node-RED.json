        "name": "Thingspeak Upload",
        "func": "let d = msg.payload;\n\nmsg.method = \"POST\";\nmsg.url = \"https://api.thingspeak.com/update.json\";\nmsg.headers = {\n    \"Content-Type\": \"application/x-www-form-urlencoded\"\n};\n\nmsg.payload =\n    \"api_key=I8EJ24Z2KNWODT4K\" +\n    \"&field1=\" + encodeURIComponent(d.soil_moisture) +\n    \"&field2=\" + encodeURIComponent(d.temperature) +\n    \"&field3=\" + encodeURIComponent(d.humidity) +\n    \"&field4=\" + encodeURIComponent(d.soil_ph) +\n    \"&field5=\" + encodeURIComponent(d.salinity) +\n    \"&field6=\" + encodeURIComponent(d.light_intensity) +\n    \"&field7=\" + encodeURIComponent(d.rainfall) +\n    \"&field8=\" + encodeURIComponent(d.pump_status);\n\nreturn msg;",
