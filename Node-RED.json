        "func": "msg.payload = {\n    soil_moisture: +(Math.random() * (90 - 10) + 10).toFixed(2),\n    temperature: +(Math.random() * (45 - 15) + 15).toFixed(2),\n    humidity: +(Math.random() * (90 - 20) + 20).toFixed(2),\n    soil_ph: +(Math.random() * (8.5 - 5.5) + 5.5).toFixed(2),\n    salinity: +(Math.random() * (3.0 - 0.1) + 0.1).toFixed(2),\n    light_intensity: Math.round(Math.random() * (1200 - 200) + 200),\n    rainfall: +(Math.random() * 20).toFixed(2),\n    pump_status: Math.random() < 0.5 ? 0 : 1\n};\nreturn msg;",
