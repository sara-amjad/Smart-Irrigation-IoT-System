    {
        "id": "8daf26b6b3ab0973",
        "type": "function",
        "z": "e74e963b5685fd3d",
        "name": "Data Cleaning",
        "func": "let d = msg.payload;\n\n// reject invalid values\nif (d.soil_moisture < 0 || d.soil_moisture > 100) return null;\nif (d.temperature < -10 || d.temperature > 60) return null;\nif (d.humidity < 0 || d.humidity > 100) return null;\nif (d.soil_ph < 0 || d.soil_ph > 14) return null;\nif (d.salinity < 0) return null;\nif (d.light_intensity < 0) return null;\nif (d.rainfall < 0) return null;\n\n// use previous valid values if current values are missing\nlet prev = context.get(\"prevData\") || {};\n\nd.soil_moisture = (d.soil_moisture === undefined || d.soil_moisture === null) ? prev.soil_moisture : d.soil_moisture;\nd.temperature = (d.temperature === undefined || d.temperature === null) ? prev.temperature : d.temperature;\nd.humidity = (d.humidity === undefined || d.humidity === null) ? prev.humidity : d.humidity;\nd.soil_ph = (d.soil_ph === undefined || d.soil_ph === null) ? prev.soil_ph : d.soil_ph;\nd.salinity = (d.salinity === undefined || d.salinity === null) ? prev.salinity : d.salinity;\nd.light_intensity = (d.light_intensity === undefined || d.light_intensity === null) ? prev.light_intensity : d.light_intensity;\nd.rainfall = (d.rainfall === undefined || d.rainfall === null) ? prev.rainfall : d.rainfall;\nd.pump_status = (d.pump_status === undefined || d.pump_status === null) ? prev.pump_status : d.pump_status;\n\n// smooth key values\nlet prevMoisture = context.get(\"prevMoisture\");\nlet prevTemp = context.get(\"prevTemp\");\n\nif (prevMoisture !== undefined) {\n    d.soil_moisture = +(((d.soil_moisture + prevMoisture) / 2).toFixed(2));\n}\nif (prevTemp !== undefined) {\n    d.temperature = +(((d.temperature + prevTemp) / 2).toFixed(2));\n}\n\ncontext.set(\"prevMoisture\", d.soil_moisture);\ncontext.set(\"prevTemp\", d.temperature);\ncontext.set(\"prevData\", d);\n\nmsg.payload = d;\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 800,
        "y": 360,
        "wires": [
