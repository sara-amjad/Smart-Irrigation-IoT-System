    {
        "id": "d17691f2720b1596",
        "type": "function",
        "z": "e74e963b5685fd3d",
        "name": "Farm Logic",
        "func": "let d = msg.payload;\n\n// 1. Automation Logic\nd.pump_status = parseFloat(d.soil_moisture) < 30 ? 1 : 0;\nd.pump_label = d.pump_status === 1 ? \"ON\" : \"OFF\";\nd.irrigation_required = d.soil_moisture < 30 ? \"YES\" : \"NO\";\nd.latest_time = new Date().toLocaleString();\n\n// 2. THE BRIDGE: Map current data to the names your template expects\n// We force them to be actual Numbers so the math (temp / 50) works\nd.temp = parseFloat(d.temperature); \nd.soil = parseFloat(d.soil_moisture);\n\nmsg.payload = d;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
