        "head": "",
        "format": "<template>\n  <div style=\"background: #000; padding: 20px; border-radius: 12px; border: 2px solid #222; height: 100%; display: flex; align-items: center; justify-content: space-between; box-shadow: inset 0 0 15px rgba(0,255,0,0.05);\">\n    \n    <div style=\"text-align: left;\">\n        <div style=\"color: #444; font-size: 9px; font-weight: bold; letter-spacing: 1px;\">SYSTEM TEMP</div>\n        <div style=\"font-size: 36px; font-weight: bold; color: #fff; font-family: monospace;\">\n            {{ msg.payload?.temp }}<span style=\"color: #ff3d00;\">°</span>\n        </div>\n        <div :style=\"{ color: msg.payload?.temp > 38 ? '#ff3d00' : '#00e676', fontSize: '10px', fontWeight: 'bold' }\">\n            STATUS: {{ msg.payload?.temp > 38 ? 'WARN' : 'OK' }}\n        </div>\n    </div>\n\n    <div style=\"display: flex; flex-direction: column-reverse; gap: 4px; width: 25px; height: 120px;\">\n        <div v-for=\"i in 10\" :key=\"i\"\n            :style=\"{\n                height: '8px',\n                width: '100%',\n                borderRadius: '2px',\n                transition: 'all 0.3s ease',\n                backgroundColor: (msg.payload?.temp_percent >= (i * 10)) \n                    ? (i < 7 ? '#00e676' : i < 9 ? '#ffea00' : '#ff3d00') \n                    : '#111',\n                boxShadow: (msg.payload?.temp_percent >= (i * 10)) \n                    ? '0 0 8px currentColor' : 'none',\n                color: (i < 7 ? '#00e676' : i < 9 ? '#ffea00' : '#ff3d00')\n            }\">\n        </div>\n    </div>\n  </div>\n</template>",
        "storeOutMessages": true,
