    {
        "id": "3643ce9184909fc7",
        "type": "function",
        "z": "e74e963b5685fd3d",
        "name": "Dashboard Logic",
        "func": "// 1. Extract raw values for easier math\nconst d = msg.payload;\n\nmsg.payload = {\n    // Existing Data\n    soil_moisture: parseFloat(d.soil_moisture),\n    temperature: parseFloat(d.temperature),\n    temp: parseFloat(d.temperature),\n    temp_percent: Math.min(Math.max((parseFloat(d.temperature) / 60) * 100, 0), 100),\n\n    // NEW DATA: Environmental Metrics\n    humidity: parseFloat(d.humidity),\n    soil_ph: parseFloat(d.soil_ph),\n    salinity: parseFloat(d.salinity),\n    light_intensity: parseInt(d.light_intensity),\n    rainfall: parseFloat(d.rainfall),\n\n    // NEW DATA: Normalized Percentages (for bars/gauges)\n    // Light: 200-1200 Lux range mapped to 0-100%\n    light_percent: Math.min(Math.max(((d.light_intensity - 200) / 1000) * 100, 0), 100),\n    // Salinity: 0-3 dS/m range mapped to 0-100%\n    salinity_percent: Math.min(Math.max((d.salinity / 3) * 100, 0), 100),\n\n    // Control Logic\n    pump_status: d.pump_status,\n    pump_label: d.pump_status === 1 ? \"ON\" : \"OFF\",\n    irrigation_required: d.soil_moisture < 30 ? \"YES\" : \"NO\",\n    status: d.soil_moisture < 20 ? \"CRITICAL\" : d.soil_moisture < 30 ? \"WARNING\" : \"NORMAL\",\n    timestamp: new Date().toLocaleString()\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
